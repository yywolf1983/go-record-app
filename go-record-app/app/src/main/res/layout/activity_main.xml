<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingLeft="0dp"
    android:paddingRight="0dp"
    android:paddingTop="6dp"
    android:paddingBottom="0dp"
    tools:context=".MainActivity">

    <!-- 顶部标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp"
        android:layout_marginBottom="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SGF 棋谱"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 工具栏卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:padding="6dp"
        android:layout_marginBottom="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_new"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_new"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/new_game"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_game"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_load"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_load"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/load_game"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/load_game"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_save"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_save"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/save_game"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/save_game"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_show_numbers"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_number"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/show_numbers"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/show_numbers"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_score"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_score"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/estimate"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/estimate"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_place"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_place"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/place_stones"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:id="@+id/btn_place_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/place_stones"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_mark"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_mark"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/mark"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mark"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_comment"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_comment"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/comment"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/comment"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_delete_branch"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_branch"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/branch"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/branch"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="1dp">
                <ImageButton
                    android:id="@+id/btn_pass"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/btn_secondary"
                    android:src="@drawable/ic_pass"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/pass"
                    android:layout_marginBottom="0dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pass"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 中部：棋盘 + 注释（注释框占满剩余空间） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.gosgf.app.view.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" />

        <!-- 步数 + 注释卡片（紧贴棋盘，占满剩余高度） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:padding="14dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/moveCountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="第 0 手"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />

            <ScrollView
                android:id="@+id/commentScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/commentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>

            <!-- 底部导航：上一步 / 下一步，图标按钮并排占满整行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <ImageButton
                    android:id="@+id/btn_previous"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_secondary"
                    android:backgroundTint="@null"
                    android:src="@drawable/ic_previous"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/action_previous" />

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/btn_secondary"
                    android:backgroundTint="@null"
                    android:src="@drawable/ic_next"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/action_next" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
