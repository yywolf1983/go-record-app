<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 顶部功能按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginBottom="4dp"
        android:background="@color/board_background">

            <!-- 第一行按钮：文件操作和显示控制 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_new"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_new"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="新建"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_load"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_load"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加载"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_save"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_save"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="保存"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_show_numbers"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_number"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="步数"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_score"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_score"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="估算"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- 第二行按钮：游戏操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_place"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_place"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:id="@+id/btn_place_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="摆子"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_mark"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_mark"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标记"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_pass"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_pass"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="虚手"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_comment"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_comment"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="注释"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="8dp">
                    <ImageButton
                        android:id="@+id/btn_delete_branch"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_branch"
                        android:background="@drawable/btn_secondary"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分支"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    <!-- 棋盘区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="99"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/board_background"
        android:padding="0dp">

        <com.gosgf.app.view.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

    <!-- 步数和注释区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <TextView
            android:id="@+id/moveCountText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="2dp"
            android:paddingHorizontal="8dp"
            android:text="步数: 0 / 0"
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/commentScrollView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/commentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

        </ScrollView>

    </LinearLayout>

    <!-- 底部导航按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/surface"
        android:elevation="2dp"
        android:padding="4dp">

        <Button
            android:id="@+id/btn_previous"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/action_previous"
            android:layout_marginHorizontal="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/action_next"
            android:layout_marginHorizontal="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>