<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 棋盘区域容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="8"
        android:background="@color/board_background"
        android:padding="4dp">

        <!-- 棋盘 -->
        <com.gosgf.app.view.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

    </FrameLayout>

    <!-- 步数和注释区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- 步数显示 -->
        <TextView
            android:id="@+id/moveCountText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="步数: 0 / 0"
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:textStyle="bold" />

        <!-- 注释显示区域 -->
        <ScrollView
            android:id="@+id/commentScrollView"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:padding="8dp">

            <TextView
                android:id="@+id/commentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

        </ScrollView>

    </LinearLayout>

    <!-- 控制按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="2dp"
        android:padding="4dp">

        <!-- 工具栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_new"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_new"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btn_load"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_load"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_save"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btn_score"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="估算"
                android:layout_marginHorizontal="4dp" />

        </LinearLayout>

        <!-- 导航栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_to_start"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="跳转"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_previous"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_previous"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_next"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_pass"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_pass"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- 功能栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_comment"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_comment"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_mark"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_mark"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_place"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="摆子"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_delete_branch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="删除分支"
                android:layout_marginHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:elevation="2dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
